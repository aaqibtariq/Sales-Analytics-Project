# create table 

```

CREATE OR REPLACE TABLE SILVER.CUSTOM_ACTIVITIES_ALL_LEADS_DETAILS (
    LEAD_ID STRING,
    ACTIVITY_ID STRING,
    ACTIVITY_AT TIMESTAMP_NTZ,
    WRAPPED_ACTIVITIES VARIANT,
    INSERT_DATE TIMESTAMP_NTZ,
    UPDATE_DATE TIMESTAMP_NTZ,
    MD5_HASH STRING
);

```

# inset

```
INSERT INTO SILVER.CUSTOM_ACTIVITIES_ALL_LEADS_DETAILS
(
    LEAD_ID,
    ACTIVITY_ID,
    ACTIVITY_AT,
    WRAPPED_ACTIVITIES,
    INSERT_DATE,
    UPDATE_DATE,
    MD5_HASH
)
SELECT
    LEAD_ID,
    ACTIVITY_ID,
    ACTIVITY_AT,
    OBJECT_CONSTRUCT_KEEP_NULL(
        'CUSTOM_ACTIVITY_ID', CUSTOM_ACTIVITY_ID,
        'TYPE', TYPE,
        'TEXT', TEXT,
        'STATUS_CHANGE', STATUS_CHANGE,
        'CREATED_BY_NAME', CREATED_BY_NAME,
        'UPDATED_BY_NAME', UPDATED_BY_NAME,
        'ATTENDEES', ATTENDEES,
        'MEETING_STARTS_AT', MEETING_STARTS_AT,
        'MEETING_END_AT', MEETING_END_AT,
        'MEETING_STATUS', MEETING_STATUS,
        'DATE_CREATED', DATE_CREATED,
        'DATE_UPDATED', DATE_UPDATED,
        'CREATED_BY_USER', CREATED_BY_USER,
        'UPDATED_BY_USER', UPDATED_BY_USER
    ) AS WRAPPED_ACTIVITIES,
    CURRENT_TIMESTAMP(),
    CURRENT_TIMESTAMP(),
    MD5(
        COALESCE(LEAD_ID, '') || '|' ||
        COALESCE(ACTIVITY_ID, '') || '|' ||
        COALESCE(CUSTOM_ACTIVITY_ID, '') || '|' ||
        COALESCE(ACTIVITY_AT::STRING, '')
    ) AS MD5_HASH
FROM SILVER.LEAD_ACTIVITIES_PROCESSED
WHERE CUSTOM_ACTIVITY_ID IS NOT NULL;


```

